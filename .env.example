# BayPhone Konfiguration
# Kopiere diese Datei zu .env und passe die Werte an:
#   cp .env.example .env

# Deine Domain (PFLICHT) - muss per DNS auf diesen Server zeigen
DOMAIN=bayphone.example.com

# E-Mail fuer Let's Encrypt und VAPID (PFLICHT)
CONTACT_EMAIL=admin@example.com

# TURN Server Secret (PFLICHT) - generiere z.B. mit: openssl rand -hex 32
TURN_SECRET=change-me-to-a-random-secret
